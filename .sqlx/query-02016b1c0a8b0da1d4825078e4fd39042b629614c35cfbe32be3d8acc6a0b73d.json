  "db_name": "PostgreSQL",
  "query": "UPDATE tasks SET title = COALESCE($3, title), description = COALESCE($4, description), status = COALESCE($5, status), closed_at = CASE WHEN $5 = 'done' THEN COALESCE(closed_at, now()) WHEN $5 = 'open' THEN NULL ELSE closed_at END WHERE id = $1 AND profile_id = $2 RETURNING id, title, description, status, created_at, closed_at",
